{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "image": {
            "type": "object",
            "properties": {
                "registry": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "pullPolicy": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            },
            "required": [
                "registry",
                "repository"
            ]
        },
        "partOfLabel": {
            "type": "string"
        },
        "runtimes": {
            "type": "object",
            "properties": {
                "vllm": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "name": {
                            "type": "string"
                        },
                        "autoSelect": {
                            "type": "boolean"
                        },
                        "priority": {
                            "type": "integer"
                        },
                        "imagePullSecrets": {
                            "type": "array"
                        },
                        "args": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "env": {
                            "type": "array"
                        },
                        "resources": {
                            "type": "object"
                        },
                        "startupProbe": {
                            "type": "object"
                        },
                        "shmSize": {
                            "type": "string"
                        }
                    }
                },
                "sparkArena": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "eugr": {
                            "$ref": "#/definitions/sparkArenaRuntime"
                        },
                        "tf5": {
                            "$ref": "#/definitions/sparkArenaRuntime"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "sparkArenaRuntime": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                },
                "args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "env": {
                    "type": "array"
                },
                "resources": {
                    "type": "object"
                },
                "startupProbe": {
                    "type": "object"
                },
                "shmSize": {
                    "type": "string"
                }
            }
        }
    }
}
